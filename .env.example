# FinScope — переменные окружения
# Скопируйте этот файл как .env и заполните значения

# База данных (Railway автоматически добавит DATABASE_URL)
DATABASE_URL=postgresql://finscope:your_password@db:5432/finscope
DB_PASSWORD=your_strong_password_here

# Безопасность — сгенерируйте случайную строку: openssl rand -hex 32
SECRET_KEY=replace_with_random_64_char_string

# Anthropic API ключ — получить на console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# CORS — домен фронтенда (для Railway: https://your-frontend.up.railway.app)
CORS_ORIGINS=http://localhost:5173,http://localhost

# URL API для фронтенда (Railway backend URL + /api)
VITE_API_URL=https://your-backend.up.railway.app/api
